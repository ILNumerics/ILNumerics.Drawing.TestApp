<Window x:Class="ILNumerics.VisualDrawingTestApp.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ILNumerics.VisualDrawingTestApp.Windows"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        xmlns:ilnWPF="clr-namespace:ILNumerics.Drawing.Controls.WPF;assembly=ILNumerics.Drawing.Platforms"
        xmlns:ilnCore="clr-namespace:ILNumerics;assembly=ILNumerics.Core"
        xmlns:ilntests="clr-namespace:ILNumerics.Drawing.Tests"
        mc:Ignorable="d"
        Title="MainWindow" Height="800" Width="1200">
    <Grid>
        <!-- 2 rows that expand with the window -->
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 3 columns: 2 flexible + 1 fixed-width right sidebar -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="380" />
            <!-- fixed right column -->
        </Grid.ColumnDefinitions>

        <!-- 4 main panels (2x2) -->
        <Border Grid.Row="0" Grid.Column="0" Margin="0" Background="#FFECECEC" BorderBrush="Black" BorderThickness="1,1,0,0" Padding="0">
            <ilnWPF:Panel x:Name="ilnPanel_WPFGDI" RendererType="GDI"/>
        </Border>

        <Border Grid.Row="0" Grid.Column="1" Margin="0" Background="#FFF3F3FF" BorderBrush="Black" BorderThickness="1,1,0,0" Padding="0">
            <ilnWPF:Panel x:Name="ilnPanel_WPFOGL" RendererType="OpenGL"/>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Margin="0" Background="#FFF1FFF1" BorderBrush="Black" BorderThickness="1,1,0,1" Padding="0">
            <wfi:WindowsFormsHost x:Name="winFormsHost1" />
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Margin="0" Background="#FFFFF1F1" BorderBrush="Black" BorderThickness="1,1,1,1" Padding="0">
            <wfi:WindowsFormsHost x:Name="winFormsHost2" />
        </Border>

        <!-- Right sidebar (fixed width) spans both rows -->
        <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="2" Background="#FFFAFAFA" Padding="12">
            <DockPanel LastChildFill="True" Margin="-2,0,0,0">
                <StackPanel Orientation="Vertical" Height="54" DockPanel.Dock="Top">
                    <TextBlock Text="Scenes" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>
                    <TextBlock Text="Select a scene from the tree:" Margin="0,0,0,8"/>
                </StackPanel>
                <ListBox x:Name="listScenes" ItemsSource="{Binding Source={x:Static ilntests:ScenesCollection.Instance}, Path=Scenes}"
                        DisplayMemberPath="Key"
                        SelectedValuePath="Value"
                        DockPanel.Dock="Bottom"
                        Margin="8" SelectionChanged="listScenes_Selected" 
                         ScrollViewer.CanContentScroll="True" ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </DockPanel>
        </Border>
        <!--<GridSplitter Grid.Column="1" Width="1" HorizontalAlignment="Right"
                      Grid.RowSpan="2" Background="#33000000" />-->

        <!-- Between rows -->
        <!--<GridSplitter Grid.Row="0" Height="5" VerticalAlignment="Bottom"
                      Grid.ColumnSpan="2" Background="#33000000" />-->
    </Grid>
</Window>
